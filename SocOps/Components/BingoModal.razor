<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50" style="backdrop-filter: blur(2px);">
    <div class="bg-gradient-card border-3 border-hot-pink rounded-lg p-8 max-w-xs w-full text-center shadow-lg box-glow-dual animate-bounce-enhanced">
        <div class="text-6xl mb-4 animate-pulse">??</div>
        <h2 class="text-4xl font-display text-hot-pink glow-pink mb-2 uppercase" style="letter-spacing: -1px;">BINGO!</h2>
        <p class="text-cyan text-lg mb-6 font-semibold">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="w-full btn-retro">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
