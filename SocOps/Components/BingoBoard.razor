@using SocOps.Models

<div class="grid grid-cols-5 gap-2 w-full max-w-md mx-auto aspect-square p-3 bg-gradient-card border-2 border-purple/50 rounded-lg box-glow-cyan">
    @for (int i = 0; i < Board.Count; i++)
    {
        var square = Board[i];
        <div class="animate-stagger-@(i + 1)">
            <BingoSquare
                Square="@square"
                IsWinning="@WinningSquareIds.Contains(square.Id)"
                OnClick="@(() => OnSquareClick.InvokeAsync(square.Id))" />
        </div>
    }
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }
}
